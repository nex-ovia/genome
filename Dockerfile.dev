# genome dev image — build/test/benchmark the `genome` binary in-container.
# No local Rust toolchain on the host (podman/docker only). Includes the C++
# toolchain so the optional `enrich` feature (llama.cpp GGUF inference) builds.
FROM docker.io/library/rust:1-slim

RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      build-essential cmake clang libclang-dev pkg-config \
      git curl ca-certificates musl-tools \
 && rm -rf /var/lib/apt/lists/* \
 && rustup target add x86_64-unknown-linux-musl

WORKDIR /work
